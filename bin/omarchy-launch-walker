#!/bin/bash

# omarchy:summary=Launch Walker and ensure its Elephant data provider is running

# Elephant is managed as a systemd user service on omarchy-nix
# (see modules/nixos/system.nix). Detect it via systemctl, not pgrep —
# the upstream `pgrep -x elephant` never matches because Nix's wrapped
# binary has comm `.elephant-wrapped`, so every menu invocation used to
# spawn a fresh detached elephant. Letting that run for a week left ~50
# orphan elephants and a flaky menu (walker would race-connect to one of
# them, often a stale instance with no providers — Style menu just exits).
if ! systemctl --user is-active --quiet elephant.service; then
  systemctl --user start elephant.service
fi

# Walker daemon: -f matches command line so this check is reliable.
if ! pgrep -f "walker --gapplication-service" > /dev/null; then
  setsid uwsm-app -- walker --gapplication-service &
fi

# Socket launch: for the default invocation (SUPER+SPACE, no flags),
# bypass GTK4 process spawning entirely. The service already has
# everything initialized — this is near-instant.
if [ $# -eq 0 ]; then
  SOCK="$XDG_RUNTIME_DIR/walker/walker.sock"
  if [ -S "$SOCK" ]; then
    exec nc -U "$SOCK"
  fi
  # Socket not ready (daemon still starting) — fall through.
fi

# Fallback: full process launch with flags (--dmenu, -m, etc.).
exec walker --width 644 --maxheight 300 --minheight 300 "$@"
